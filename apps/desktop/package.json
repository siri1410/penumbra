{
  "name": "@penumbra/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Penumbra desktop overlay.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "pnpm run build && electron-builder",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "start": "electron ."
  },
  "dependencies": {
    "@penumbra/core": "workspace:*",
    "@penumbra/db": "workspace:*",
    "@penumbra/providers": "workspace:*",
    "@penumbra/types": "workspace:*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
